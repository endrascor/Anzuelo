@model IEnumerable<Anzuelo.Application.DTOs.ComboDTO>

@{
    ViewData["Title"] = "Combos";
}

<style>
    .page-title {
        font-weight: 800;
        color: var(--anzuelo-primary);
        margin-bottom: 1.5rem;
    }

    .combo-card {
        border: none;
        border-radius: .5rem;
        overflow: hidden;
        background: #fff;
        box-shadow: 0 2px 12px rgba(10, 47, 90, .08);
        transition: transform .15s ease, box-shadow .15s ease;
    }

        .combo-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 18px rgba(10, 47, 90, .12);
        }

    .combo-img {
        width: 100%;
        aspect-ratio: 1 / 1;
        object-fit: cover;
        background: #f5f5f5;
        border-bottom: 1px solid #edf0f2;
    }

    .combo-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--anzuelo-primary);
        margin-bottom: .3rem;
    }

    .combo-desc {
        font-size: .85rem;
        color: #666;
        min-height: 40px;
    }

    .combo-price {
        display: inline-block;
        background: var(--anzuelo-accent);
        color: #fff;
        font-weight: 700;
        font-size: .85rem;
        padding: .35rem .8rem;
        border-radius: 2rem;
        margin-top: .5rem;
    }

    .badge-cat {
        background: var(--anzuelo-primary);
        color: #fff;
        font-size: .75rem;
        font-weight: 600;
        padding: .3em .75em;
        border-radius: 2rem;
        white-space: nowrap;
    }

    .card-footer-custom {
        background: #fff;
        border-top: 1px solid #edf0f2;
    }

    /* BOTÓN estilo productos */
    .btn-anzuelo {
        background: transparent;
        border: 2px solid var(--anzuelo-accent);
        color: var(--anzuelo-accent);
        font-size: .85rem;
        font-weight: 600;
        padding: .3rem .9rem;
        border-radius: .35rem;
        text-decoration: none;
        transition: background .2s, color .2s;
        display: inline-flex;
        align-items: center;
        gap: .3rem;
    }

        .btn-anzuelo:hover {
            background: var(--anzuelo-accent);
            color: #fff;
        }

    .combo-card:hover .combo-title {
        color: var(--anzuelo-accent);
    }
</style>

<div class="page-hero">
    <div class="container">
        <h1><i class="bi bi-bag-heart me-2"></i>Combos</h1>
        <p class="page-hero-sub">Selecciones especiales con nuestros mejores mariscos</p>
    </div>
</div>

<div class="container">

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox" style="font-size:3rem;opacity:.4;"></i>
            <h5 class="mt-3">No hay combos disponibles por el momento</h5>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">

            @foreach (var item in Model)
            {
                <div class="col">

                    <div class="card combo-card h-100">

                        @if (item.Imagen != null)
                        {
                            <img class="combo-img"
                                 src="data:image/png;base64,@Convert.ToBase64String(item.Imagen)"
                                 alt="@item.Nombre" />
                        }
                        else
                        {
                            <img class="combo-img"
                                 src="~/images/no-image.png"
                                 alt="Sin imagen" />
                        }

                        <div class="card-body d-flex flex-column">

                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div class="combo-title">@item.Nombre</div>
                                <span class="badge-cat">@item.NombreCategoria</span>
                            </div>

                            <p class="combo-desc flex-grow-1">
                                @item.Descripcion
                            </p>

                            <div class="d-flex justify-content-between align-items-center mt-3">

                                <a asp-action="Details"
                                   asp-route-id="@item.IdCombo"
                                   class="btn-anzuelo">

                                    Ver detalle
                                    <i class="bi bi-arrow-right"></i>

                                </a>

                                <span class="combo-price">
                                    ₡@item.PrecioTotal.ToString("N2")
                                </span>

                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>