@model Anzuelo.Application.DTOs.ComboDTO
@{
    ViewData["Title"] = "Detalle del Combo";
}

<style>
    /* HERO igual a Producto */
    .page-hero {
        background: linear-gradient(135deg, var(--anzuelo-primary), #184f8a);
        color: #fff;
        padding: 1.8rem 0;
        margin-bottom: 1.5rem;
        border-radius: .5rem;
        text-align: center;
    }

        .page-hero h1 {
            font-weight: 700;
            margin: 0;
        }

    .page-hero-sub {
        opacity: .9;
        font-size: .95rem;
    }

    /* CARD principal */
    .detail-card {
        border: none;
        border-left: 4px solid var(--anzuelo-accent);
        border-radius: .5rem;
        background: #fff;
    }

    /* PRECIO */
    .precio-destacado {
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--anzuelo-accent);
    }

    /* FILA PRODUCTOS */
    .producto-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: .8rem 1.1rem;
        border-bottom: 1px solid #edf0f2;
        transition: background .15s;
    }

        .producto-row:last-child {
            border-bottom: none;
        }

        .producto-row:hover {
            background: #fff5ee;
        }

    /* BADGE cantidad */
    .badge-cant {
        background: var(--anzuelo-accent);
        color: #fff;
        font-size: .78rem;
        font-weight: 700;
        padding: .25em .75em;
        border-radius: 2rem;
    }

    /* BOX precio */
    .subtotal-box {
        background: #fff5ee;
        border-radius: .4rem;
        padding: .9rem 1.1rem;
        margin-top: 1.1rem;
    }

    /* BOTÓN VOLVER estilo Producto */
    .btn-back {
        background: transparent;
        border: 2px solid var(--anzuelo-accent);
        color: var(--anzuelo-accent);
        font-weight: 600;
        border-radius: .4rem;
        padding: .45rem 1rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        transition: .2s;
    }

        .btn-back:hover {
            background: var(--anzuelo-accent);
            color: #fff;
        }
</style>

<div class="page-hero">
    <div class="container">
        <h1><i class="bi bi-bag-heart me-2"></i>@Model.Nombre</h1>
        <p class="page-hero-sub">Detalle del combo</p>
    </div>
</div>

<div class="container">
    <div class="row g-4">

        <!-- INFO -->
        <div class="col-lg-5">
            <div class="card detail-card shadow-sm h-100">
                <div class="card-body p-4">

                    <h6><strong style="color:var(--anzuelo-primary);">Información</strong></h6>

                    <p><strong>Descripción:</strong></p>
                    <p>@Model.Descripcion</p>

                    <p><strong>Categoría:</strong></p>
                    <p>
                        <span class="badge rounded-pill"
                              style="background:var(--anzuelo-primary);color:#fff;">
                            @Model.NombreCategoria
                        </span>
                    </p>

                    <p><strong>Estado:</strong></p>
                    <p>
                        <span class="badge rounded-pill"
                              style="background:#eaf4de;color:#3d6b1a;">
                            @Model.NombreEstado
                        </span>
                    </p>

                    <div class="subtotal-box">
                        <p class="mb-1"><strong>Precio total</strong></p>
                        <p class="precio-destacado mb-0">
                            ₡@Model.PrecioTotal.ToString("N2")
                        </p>
                    </div>

                </div>
            </div>
        </div>

        <!-- PRODUCTOS -->
        <div class="col-lg-7">
            <div class="card shadow-sm detail-card" style="border:none;">
                <div class="card-body p-4">

                    <h6>
                        <i class="bi bi-list-ul me-1"></i>
                        <strong style="color:var(--anzuelo-primary);">
                            Productos incluidos
                        </strong>
                    </h6>

                </div>

                @foreach (var producto in Model.Productos)
                {
                    <div class="producto-row">
                        <span>
                            <i class="bi bi-circle-fill me-2"
                               style="font-size:.45rem;color:var(--anzuelo-accent);"></i>
                            @producto.NombreProducto
                        </span>
                        <span class="badge-cant">
                            ×@producto.Cantidad
                        </span>
                    </div>
                }

            </div>
        </div>

    </div>

    <!-- BOTÓN VOLVER -->
    <div class="mt-4 text-center">
        <a href="javascript:history.back()" class="btn-back">
            <i class="bi bi-arrow-left"></i>
            Volver a Combos
        </a>
    </div>

</div>