@model Anzuelo.Application.DTOs.ComboDTO
@{
    ViewData["Title"] = "Detalle del Combo";
}

<h1 class="mb-4">@Model.Nombre</h1>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Descripción</dt>
            <dd class="col-sm-9">@Model.Descripcion</dd>

            <dt class="col-sm-3">Categoría</dt>
            <dd class="col-sm-9">@Model.NombreCategoria</dd>

            <dt class="col-sm-3">Estado</dt>
            <dd class="col-sm-9">@Model.NombreEstado</dd>

            <dt class="col-sm-3">Precio Total</dt>
            <dd class="col-sm-9">₡@Model.PrecioTotal.ToString("N2")</dd>
        </dl>
    </div>
</div>

<h4 class="mb-3">Productos del Combo</h4>
<ul class="list-group">
    @foreach (var producto in Model.Productos)
    {
        <li class="list-group-item d-flex justify-content-between align-items-center">
            @producto.NombreProducto
            <span class="badge bg-primary rounded-pill">Cantidad: @producto.Cantidad</span>
        </li>
    }
</ul>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>