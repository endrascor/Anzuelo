@model Anzuelo.Application.DTOs.ComboDTO
@{
    ViewData["Title"] = "Crear combo";
}

<style>
    .create-card {
        border: none;
        border-radius: .75rem;
        box-shadow: 0 4px 18px rgba(10,47,90,.10);
        overflow: hidden;
    }

    .create-card-header {
        background: var(--anzuelo-primary);
        color: #fff;
        padding: 1.25rem 1.5rem;
    }

        .create-card-header h2 {
            margin: 0;
            font-weight: 700;
        }

    .form-section {
        border: 1px solid #dee2e6;
        border-radius: .65rem;
        padding: 1.25rem;
        margin-bottom: 1.5rem;
        background: #fff;
    }

    .form-section-title {
        color: var(--anzuelo-primary);
        font-size: 1.15rem;
        font-weight: 700;
        margin-bottom: 1rem;
    }

    .producto-fila {
        background: #f8f9fa;
        border: 1px solid #e5e8eb;
        border-radius: .55rem;
        padding: 1rem;
        margin-bottom: 1rem;
    }

    .imagen-preview-card {
        border: 1px solid #dee2e6;
        border-radius: .6rem;
        overflow: hidden;
        height: 100%;
        background: #fff;
        position: relative;
        max-width: 260px;
    }

    .imagen-preview {
        width: 100%;
        height: 170px;
        object-fit: cover;
        background: #f5f5f5;
    }

    .btn-eliminar-imagen {
        position: absolute;
        top: .45rem;
        right: .45rem;
        z-index: 5;
        width: 36px;
        height: 36px;
        padding: 0;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 2px 7px rgba(0,0,0,.25);
    }

    .imagen-x {
        color: #fff;
        font-size: 1.65rem;
        font-weight: 700;
        line-height: 1;
        display: block;
        transform: translateY(-1px);
    }

    .imagen-preview-info {
        padding: .7rem;
    }

    .btn-guardar-combo {
        background: var(--anzuelo-accent);
        border-color: var(--anzuelo-accent);
        color: #fff;
        font-weight: 600;
    }

        .btn-guardar-combo:hover {
            background: var(--anzuelo-primary);
            border-color: var(--anzuelo-primary);
            color: #fff;
        }

    .mensaje-validacion-seccion {
        font-weight: 600;
        margin-top: .65rem;
    }
</style>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-11">
            <div class="card create-card">
                <div class="create-card-header">
                    <h2><i class="bi bi-bag-heart me-2"></i>Crear combo</h2>
                    <p class="mb-0 mt-1">Complete la información, la imagen y los productos incluidos.</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" asp-antiforgery="true" enctype="multipart/form-data" id="formCombo">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <section class="form-section">
                            <div class="form-section-title"><i class="bi bi-info-circle me-1"></i>Información general</div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Nombre" class="form-label"></label>
                                    <input asp-for="Nombre" class="form-control" placeholder="Nombre del combo" />
                                    <span asp-validation-for="Nombre" class="text-danger"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="PrecioTotal" class="form-label"></label>
                                    <div class="input-group">
                                        <span class="input-group-text">₡</span>
                                        <input asp-for="PrecioTotal" class="form-control" type="number" step="0.01" placeholder="0.00" />
                                    </div>
                                    <span asp-validation-for="PrecioTotal" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label asp-for="Descripcion" class="form-label"></label>
                                <textarea asp-for="Descripcion" class="form-control" rows="3" placeholder="Descripción del combo"></textarea>
                                <span asp-validation-for="Descripcion" class="text-danger"></span>
                            </div>
                        </section>

                        <section class="form-section">
                            <div class="form-section-title"><i class="bi bi-tags me-1"></i>Clasificación</div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="IdCategoriaCombo" class="form-label"></label>
                                    @Html.DropDownListFor(m => m.IdCategoriaCombo, (SelectList)ViewBag.Categorias, "Seleccione una categoría", new { @class = "form-select" })
                                    <span asp-validation-for="IdCategoriaCombo" class="text-danger"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="IdEstadoCombo" class="form-label"></label>
                                    @Html.DropDownListFor(m => m.IdEstadoCombo, (SelectList)ViewBag.Estados, "Seleccione un estado", new { @class = "form-select" })
                                    <span asp-validation-for="IdEstadoCombo" class="text-danger"></span>
                                </div>
                            </div>
                        </section>

                        <section class="form-section" id="seccionImagen">
                            <div class="form-section-title"><i class="bi bi-image me-1"></i>Imagen del combo</div>
                            <div class="mb-3">
                                <input type="file" id="imagenFile" name="imagenFile" class="form-control" accept="image/*" required />
                                <div class="form-text">Tamaño máximo: 5 MB.</div>
                            </div>
                            <div id="vistaPreviaImagen"></div>
                            <div id="errorImagenCliente" class="text-danger mensaje-validacion-seccion"></div>
                        </section>

                        <section class="form-section" id="seccionProductos">
                            <div class="form-section-title"><i class="bi bi-basket me-1"></i>Productos del combo</div>
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <p class="text-muted mb-0">Agregue los productos incluidos en este combo.</p>
                                <button type="button" id="btnAgregarProducto" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-plus-lg me-1"></i>Agregar producto
                                </button>
                            </div>
                            <div id="contenedorProductos"></div>
                            <div id="mensajeSinProductos" class="alert alert-light border mb-0">No se han agregado productos.</div>
                            <div id="errorProductosCliente" class="text-danger mensaje-validacion-seccion"></div>
                            <div id="productosHidden"></div>
                        </section>

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="IndexAdmin" class="btn btn-secondary"><i class="bi bi-arrow-left me-1"></i>Cancelar</a>
                            <button type="submit" class="btn btn-guardar-combo"><i class="bi bi-floppy me-1"></i>Guardar combo</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<template id="plantillaProducto">
    <div class="row align-items-end producto-fila">
        <div class="col-md-7 mb-2">
            <label class="form-label">Producto</label>
            <select class="form-select producto-select">
                @foreach (var opcion in (SelectList)ViewBag.Productos)
                {
                    <option value="@opcion.Value">@opcion.Text</option>
                }
            </select>
        </div>
        <div class="col-md-3 mb-2">
            <label class="form-label">Cantidad</label>
            <input type="number" class="form-control cantidad-input" min="1" value="1" />
        </div>
        <div class="col-md-2 mb-2">
            <button type="button" class="btn btn-outline-danger w-100 btnEliminarProducto">
                <i class="bi bi-trash me-1"></i>Quitar
            </button>
        </div>
    </div>
</template>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const contenedorProductos = document.getElementById('contenedorProductos');
        const plantillaProducto = document.getElementById('plantillaProducto');
        const mensajeSinProductos = document.getElementById('mensajeSinProductos');
        const errorProductosCliente = document.getElementById('errorProductosCliente');

        function obtenerFilasProductos() {
            return Array.from(contenedorProductos.querySelectorAll('.producto-fila'));
        }

        function actualizarMensajeProductos() {
            mensajeSinProductos.style.display = obtenerFilasProductos().length === 0 ? 'block' : 'none';
        }

        function agregarFilaProducto() {
            contenedorProductos.insertAdjacentHTML('beforeend', plantillaProducto.innerHTML);
            errorProductosCliente.textContent = '';
            actualizarMensajeProductos();
        }

        document.getElementById('btnAgregarProducto').addEventListener('click', agregarFilaProducto);

        contenedorProductos.addEventListener('click', function (e) {
            const btn = e.target.closest('.btnEliminarProducto');
            if (btn) { btn.closest('.producto-fila').remove(); actualizarMensajeProductos(); }
        });

        // Vista previa de la imagen con opción de quitar (equis)
        const inputImagen = document.getElementById('imagenFile');
        const vistaPreviaImagen = document.getElementById('vistaPreviaImagen');
        const errorImagenCliente = document.getElementById('errorImagenCliente');
        let urlTemporal = null;

        inputImagen.addEventListener('change', function () {
            vistaPreviaImagen.innerHTML = '';
            if (urlTemporal) { URL.revokeObjectURL(urlTemporal); urlTemporal = null; }
            const archivo = inputImagen.files[0];
            if (!archivo) return;

            urlTemporal = URL.createObjectURL(archivo);
            vistaPreviaImagen.innerHTML = `
                <div class="imagen-preview-card">
                    <button type="button" class="btn btn-danger btn-sm btn-eliminar-imagen" id="btnQuitarImagenNueva" title="Quitar imagen">
                        <span class="imagen-x">&times;</span>
                    </button>
                    <img src="${urlTemporal}" class="imagen-preview" alt="Vista previa" />
                    <div class="imagen-preview-info">
                        <small class="d-block text-truncate">${archivo.name}</small>
                    </div>
                </div>`;

            document.getElementById('btnQuitarImagenNueva').addEventListener('click', function () {
                inputImagen.value = '';
                vistaPreviaImagen.innerHTML = '';
            });

            errorImagenCliente.textContent = '';
        });

        document.getElementById('formCombo').addEventListener('submit', function (e) {
            const filas = obtenerFilasProductos();
            let valido = true;

            if (filas.length === 0) {
                errorProductosCliente.textContent = 'Debe agregar al menos un producto al combo.';
                valido = false;
            } else {
                errorProductosCliente.textContent = '';
            }

            if (!inputImagen.files[0]) {
                errorImagenCliente.textContent = 'Debe seleccionar una imagen para el combo.';
                valido = false;
            }

            if (!valido) { e.preventDefault(); return; }

            const contenedor = document.getElementById('productosHidden');
            contenedor.innerHTML = '';
            filas.forEach(fila => {
                const idProducto = fila.querySelector('.producto-select').value;
                const cantidad = fila.querySelector('.cantidad-input').value;
                if (idProducto) {
                    contenedor.innerHTML += `
                        <input type="hidden" name="productosIds" value="${idProducto}" />
                        <input type="hidden" name="productosCantidades" value="${cantidad}" />`;
                }
            });
        });

        actualizarMensajeProductos();
    </script>
}