@model Anzuelo.Application.DTOs.ComboDTO

@{
    ViewData["Title"] = "Crear";
}

<h1>Crear</h1>

<h4>Combo</h4>
<hr />
<div>
    <form asp-action="Create" asp-antiforgery="true" class="row" enctype="multipart/form-data" id="formCombo">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="col-md-6">
            <div class="form-group mb-3">
                <label asp-for="Nombre" class="control-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="PrecioTotal" class="control-label"></label>
                <input asp-for="PrecioTotal" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="PrecioTotal" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Descripcion" class="control-label"></label>
                <textarea asp-for="Descripcion" class="form-control" rows="2"></textarea>
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>
        </div>

        <div class="col-md-6">
            <div class="form-group mb-3">
                <label asp-for="IdCategoriaCombo" class="control-label"></label>
                @Html.DropDownListFor(m => m.IdCategoriaCombo,
                (SelectList)ViewBag.Categorias, 
                                "Seleccione una categoría",
                                new { @class = "form-select" })
                <span asp-validation-for="IdCategoriaCombo" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="IdEstadoCombo" class="control-label"></label>
                @Html.DropDownListFor(m => m.IdEstadoCombo,
                                (SelectList)ViewBag.Estados, 
                                "Seleccione un estado",
                                new { @class = "form-select" })
                <span asp-validation-for="IdEstadoCombo" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Imagen del Combo</label>
                <input type="file" name="imagenFile" class="form-control" accept="image/*" required />
            </div>
        </div>

        <hr class="my-4" />

        <div class="col-12">
            <h5>Productos del Combo</h5>
            <table class="table" id="tablaProductos">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th style="width:120px;">Cantidad</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
            <button type="button" id="btnAgregarProducto" class="btn btn-outline-secondary btn-sm mb-3">
                <i class="bi bi-plus-lg"></i> Agregar producto
            </button>
            <div id="productosHidden"></div>
        </div>

        <div class="form-group row mt-3">
            <div class="btn-group" role="group">
                <a asp-action="IndexAdmin" class="btn btn-dark">Regresar al listado</a>
                <button type="submit" class="btn btn-primary">Crear</button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const productosOptionsHtml = `@Html.Raw(((SelectList)ViewBag.Productos).Aggregate("", (acc, item) => acc + $"<option value='{item.Value}'>{item.Text}</option>"))`;

        document.getElementById('btnAgregarProducto').addEventListener('click', function () {
            const tbody = document.querySelector('#tablaProductos tbody');
            const fila = document.createElement('tr');
            fila.innerHTML = `
                <td><select class="form-select producto-select">${productosOptionsHtml}</select></td>
                <td><input type="number" class="form-control cantidad-input" min="1" value="1" /></td>
                <td><button type="button" class="btn btn-outline-danger btn-quitar"><i class="bi bi-trash"></i></button></td>`;
            tbody.appendChild(fila);
        });

        document.querySelector('#tablaProductos').addEventListener('click', function (e) {
            const btn = e.target.closest('.btn-quitar');
            if (btn) btn.closest('tr').remove();
        });

        document.getElementById('formCombo').addEventListener('submit', function (e) {
            const filas = document.querySelectorAll('#tablaProductos tbody tr');
            if (filas.length === 0) {
                e.preventDefault();
                Swal.fire('Atención', 'Debe agregar al menos un producto al combo.', 'warning');
                return;
            }
            const contenedor = document.getElementById('productosHidden');
            contenedor.innerHTML = '';
            filas.forEach(fila => {
                const idProducto = fila.querySelector('.producto-select').value;
                const cantidad = fila.querySelector('.cantidad-input').value;
                if (idProducto) {
                    contenedor.innerHTML += `
                        <input type="hidden" name="productosIds" value="${idProducto}" />
                        <input type="hidden" name="productosCantidades" value="${cantidad}" />`;
                }
            });
        });
    </script>
}