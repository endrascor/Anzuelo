@model Anzuelo.Application.DTOs.PreparacionDTO
@{
    ViewData["Title"] = "Detalle del Proceso de Preparación";
}
<h1 class="mb-4">Proceso de Preparación</h1>
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Descripción</dt>
            <dd class="col-sm-9">@Model.Descripcion</dd>
            <dt class="col-sm-3">Producto(s)</dt>
            <dd class="col-sm-9">@string.Join(", ", Model.NombresProductos)</dd>
        </dl>
    </div>
</div>
<h4 class="mb-3">Estaciones de Preparación</h4>
<ul class="list-group">
    @foreach (var estacion in Model.Estaciones.OrderBy(e => e.NumeroOrden))
    {
        <li class="list-group-item d-flex justify-content-between align-items-center">
            <span>
                <strong>#@estacion.NumeroOrden</strong> — @estacion.NombreEstacion
            </span>
            <span class="badge bg-secondary rounded-pill">
                @estacion.TiempoEstimadoMinutos min
            </span>
        </li>
    }
</ul>
<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>