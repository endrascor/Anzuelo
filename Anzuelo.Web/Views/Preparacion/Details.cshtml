@model Anzuelo.Application.DTOs.PreparacionDTO
@{
    ViewData["Title"] = "Detalle del Proceso de Preparación";
    var tiempoTotal = Model.Estaciones.Sum(e => e.TiempoEstimadoMinutos);
}

<style>
    .page-hero {
        background: linear-gradient(135deg, var(--anzuelo-primary), #184f8a);
        color: #fff;
        padding: 1.8rem 0;
        margin-bottom: 1.5rem;
        border-radius: .5rem;
        text-align: center;
    }

        .page-hero h1 {
            font-weight: 700;
            margin: 0;
        }

    .page-hero-sub {
        opacity: .9;
        font-size: .95rem;
    }

    .detail-card {
        border: none;
        border-left: 4px solid var(--anzuelo-accent);
        border-radius: .5rem;
        background: #fff;
    }

    .timeline {
        position: relative;
        padding-left: 2.75rem;
    }

        .timeline::before {
            content: '';
            position: absolute;
            left: .95rem;
            top: .6rem;
            bottom: .6rem;
            width: 2px;
            background: linear-gradient(to bottom, var(--anzuelo-accent), rgba(230, 126, 34, .2));
            border-radius: 1px;
        }

    .tl-item {
        position: relative;
        background: #fff;
        border: 1px solid #e5edf0;
        border-radius: .45rem;
        padding: .8rem 1rem;
        margin-bottom: .8rem;
        transition: box-shadow .15s;
    }

        .tl-item:hover {
            box-shadow: 0 3px 12px rgba(10, 47, 90, .1);
        }

    .tl-dot {
        position: absolute;
        left: -2.1rem;
        top: 50%;
        transform: translateY(-50%);
        width: 1.5rem;
        height: 1.5rem;
        background: var(--anzuelo-accent);
        color: #fff;
        font-size: .68rem;
        font-weight: 700;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .tl-nombre {
        font-weight: 600;
        color: var(--anzuelo-primary);
    }

    .tl-tiempo {
        font-size: .8rem;
        font-weight: 600;
        color: var(--anzuelo-accent);
        background: #fff5ee;
        padding: .2em .65em;
        border-radius: 2rem;
        white-space: nowrap;
        display: inline-flex;
        align-items: center;
        gap: .3rem;
    }

    .btn-back {
        background: transparent;
        border: 2px solid var(--anzuelo-accent);
        color: var(--anzuelo-accent);
        font-weight: 600;
        border-radius: .4rem;
        padding: .45rem 1rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        transition: .2s;
    }

        .btn-back:hover {
            background: var(--anzuelo-accent);
            color: #fff;
        }
</style>

<div class="page-hero">
    <div class="container">
        <h1><i class="bi bi-diagram-3 me-2"></i>Proceso de Preparación</h1>
        <p class="page-hero-sub">@string.Join(", ", Model.NombresProductos)</p>
    </div>
</div>

<div class="container">

    <div class="row g-4">

        <div class="col-lg-4">
            <div class="card detail-card shadow-sm h-100">
                <div class="card-body p-4">

                    <h6 style="color:var(--anzuelo-primary);font-weight:700;">Información</h6>

                    <p><strong>Descripción:</strong><br />@Model.Descripcion</p>

                    <p><strong>Producto(s):</strong><br />@string.Join(", ", Model.NombresProductos)</p>

                    <p>
                        <strong>Estaciones:</strong>
                        <span class="badge rounded-pill"
                              style="background:var(--anzuelo-accent);color:#fff;padding:.4em .9em;">
                            @Model.Estaciones.Count
                        </span>
                    </p>

                    <div style="background:#fff5ee;padding:1rem;border-radius:.4rem;">
                        <strong style="color:var(--anzuelo-primary);">Tiempo total</strong>
                        <h3 style="color:var(--anzuelo-accent);font-weight:800;">
                            @tiempoTotal min
                        </h3>
                    </div>

                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm" style="border:none;">
                <div class="card-body p-4">

                    <h5 style="color:var(--anzuelo-primary);font-weight:700;">
                        Estaciones de preparación
                    </h5>

                    <div class="timeline">

                        @foreach (var estacion in Model.Estaciones.OrderBy(e => e.NumeroOrden))
                        {
                            <div class="tl-item">
                                <span class="tl-dot">@estacion.NumeroOrden</span>

                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="tl-nombre">@estacion.NombreEstacion</span>
                                    <span class="tl-tiempo">
                                        <i class="bi bi-clock"></i>
                                        @estacion.TiempoEstimadoMinutos min
                                    </span>
                                </div>
                            </div>
                        }

                    </div>

                </div>
            </div>
        </div>

    </div>

    <div class="mt-4">
        <a href="javascript:history.back()" class="btn-back">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>

</div>