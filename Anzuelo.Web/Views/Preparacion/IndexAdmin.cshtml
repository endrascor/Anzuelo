@model X.PagedList.IPagedList<Anzuelo.Application.DTOs.PreparacionDTO>
@using X.PagedList.Mvc.Core

@{
    ViewData["Title"] = "Administrar Procesos de Preparación";
}

<div class="page-hero">
    <div class="container d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="bi bi-diagram-3 me-2"></i>Administrar Preparación</h1>
            <p class="page-hero-sub">Crear, editar y consultar procesos de preparación</p>
        </div>
        <a asp-action="Create" class="btn btn-light fw-bold">
            <i class="bi bi-plus-circle me-1"></i>Nuevo Proceso
        </a>
    </div>
</div>

<div class="container">
    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox" style="font-size:3rem;opacity:.4;"></i>
            <h5 class="mt-3">No hay procesos registrados aún</h5>
        </div>
    }
    else
    {
        <div class="prep-table-wrap">
            <table class="table prep-table mb-0">
                <thead>
                    <tr>
                        <th>Proceso de Preparación</th>
                        <th class="text-center">Pasos</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Descripcion</td>
                            <td class="text-center"><span class="badge-pasos">@item.Estaciones.Count</span></td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.IdPreparacion" class="btn-ver-prep">
                                    <i class="bi bi-pencil-square"></i> Editar
                                </a>
                                <a asp-action="Details" asp-route-id="@item.IdPreparacion" class="btn-ver-prep ms-1">
                                    <i class="bi bi-eye"></i> Ver
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-center mt-4">
            @Html.PagedListPager(Model, page => Url.Action("IndexAdmin", new { page }), 
                new PagedListRenderOptions {
                    LiElementClasses = new string[] { "page-item" },
                    PageClasses = new string[] { "page-link" }
                })
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    @if (ViewBag.NotificationMessage != null)
    {
        @Html.Raw(ViewBag.NotificationMessage)
    }
}