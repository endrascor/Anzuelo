<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Anzuelo</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Anzuelo.Web.styles.css" asp-append-version="true" />
</head>
<body style="min-height:100vh; display:flex; flex-direction:column;">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark shadow-sm"
             style="background-color: var(--anzuelo-primary);">

            <div class="container">

                <a class="navbar-brand d-flex align-items-center"
                   asp-controller="Home"
                   asp-action="Index">

                    <img src="~/images/logo.jpeg"
                         alt="Logo"
                         width="60"
                         height="60"
                         class="me-3" />

                    <span style="font-size:2rem;font-weight:bold;">
                        ANZUELO
                    </span>

                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarAnzuelo">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse justify-content-end"
                     id="navbarAnzuelo">

                    <ul class="navbar-nav text-end">

                        <li class="nav-item mx-3">
                            <a class="nav-link text-white fs-5"
                               asp-controller="Home"
                               asp-action="Index">
                                Inicio
                            </a>
                        </li>

                        <li class="nav-item mx-3">
                            <a class="nav-link text-white fs-5"
                               asp-controller="Combo"
                               asp-action="Index">
                                Combos
                            </a>
                        </li>

                        <li class="nav-item mx-3">
                            <a class="nav-link text-white fs-5"
                               asp-controller="Producto"
                               asp-action="Index">
                                Productos
                            </a>
                        </li>

                        <li class="nav-item mx-3">
                            <a class="nav-link text-white fs-5"
                               asp-controller="Preparacion"
                               asp-action="Index">
                                Preparación
                            </a>
                        </li>

                    </ul>

                </div>

            </div>

        </nav>
    </header>
    <div class="container" style="flex:1;">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="mt-5 py-4 text-center text-white"
            style="background-color: var(--anzuelo-primary);">

        <div class="container">

            <h5>Soda Anzuelo</h5>

            <p>
                Especialistas en ceviches, mariscos frescos
                y comida tradicional costarricense.
            </p>

            <p>
                📍 Puntarenas, Costa Rica
            </p>

            <p>
                📞 2222-2222
            </p>

            <p>
                ✉ contacto@anzuelo.com
            </p>

            <hr />

            <small>
                © 2026 Sistema El Anzuelo.
                Todos los derechos reservados.
            </small>

        </div>

    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>