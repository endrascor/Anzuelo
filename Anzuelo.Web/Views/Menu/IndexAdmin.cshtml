@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<Anzuelo.Application.DTOs.MenuDTO>

@{
    ViewData["Title"] = "Administrar Menús";
}

<style>
    .menu-table-wrap {
        background: #fff;
        border-radius: .5rem;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(10, 47, 90, .08);
    }

    .menu-table thead th {
        background-color: var(--anzuelo-primary);
        color: #fff;
        font-size: .76rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        border: none;
        padding: .9rem 1.2rem;
    }

    .menu-table tbody tr {
        border-bottom: 1px solid #edf0f2;
        transition: background .15s;
    }

        .menu-table tbody tr:last-child {
            border-bottom: none;
        }

        .menu-table tbody tr:hover {
            background: #fff5ee;
        }

    .menu-table td {
        padding: .85rem 1.2rem;
        vertical-align: middle;
        border: none;
    }

    .descripcion-menu {
        max-width: 320px;
        white-space: normal;
    }

    .badge-activo,
    .badge-inactivo {
        display: inline-block;
        min-width: 75px;
        padding: .3rem .8rem;
        border-radius: 2rem;
        color: #fff;
        font-size: .75rem;
        font-weight: 700;
        text-align: center;
    }

    .badge-activo {
        background: var(--anzuelo-success);
    }

    .badge-inactivo {
        background: #6c757d;
    }

    .btn-accion-menu {
        background: transparent;
        border: 2px solid var(--anzuelo-accent);
        color: var(--anzuelo-accent);
        font-size: .8rem;
        font-weight: 600;
        padding: .28rem .85rem;
        border-radius: .35rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        transition: background .2s, color .2s;
    }

        .btn-accion-menu:hover {
            background: var(--anzuelo-accent);
            color: #fff;
        }

    .top-actions {
        display: flex;
        justify-content: flex-end;
        flex-wrap: wrap;
        gap: .75rem;
        margin-bottom: 1rem;
    }

    .btn-menu-principal {
        background: var(--anzuelo-accent);
        color: #fff;
        border: 2px solid var(--anzuelo-accent);
        padding: .55rem 1rem;
        border-radius: .4rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        transition: opacity .2s;
    }

        .btn-menu-principal:hover {
            opacity: .85;
            color: #fff;
        }

    .btn-menu-secundario {
        background: transparent;
        color: var(--anzuelo-accent);
        border: 2px solid var(--anzuelo-accent);
        padding: .55rem 1rem;
        border-radius: .4rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        transition: background .2s, color .2s;
    }

        .btn-menu-secundario:hover {
            background: var(--anzuelo-accent);
            color: #fff;
        }

    .fecha-columna,
    .horario-columna {
        white-space: nowrap;
    }

    .pagination {
        margin-bottom: 0;
    }

        .pagination .page-link {
            color: var(--anzuelo-primary);
            border-color: #dee2e6;
            font-size: .85rem;
            padding: .35rem .75rem;
        }

        .pagination .page-item.active .page-link {
            background-color: var(--anzuelo-primary);
            border-color: var(--anzuelo-primary);
            color: #fff;
        }

        .pagination .page-link:hover {
            background-color: #fff5ee;
            color: var(--anzuelo-accent);
            border-color: var(--anzuelo-accent);
        }
</style>

<div class="page-hero">

    <div class="container">

        <h1>
            <i class="bi bi-journal-text me-2"></i>
            Administrar Menús
        </h1>

        <p class="page-hero-sub">
            Gestión de menús registrados en el sistema
        </p>

    </div>

</div>

<div class="container">

    <div class="top-actions">

        <a asp-controller="Menu"
           asp-action="Details"
           class="btn-menu-secundario">

            <i class="bi bi-eye"></i>
            Ver menú disponible

        </a>

        <a asp-controller="Menu"
           asp-action="Create"
           class="btn-menu-principal">

            <i class="bi bi-plus-circle"></i>
            Crear menú

        </a>

    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 text-muted">

            <i class="bi bi-inbox"
               style="font-size: 3rem; opacity: .4;">
            </i>

            <h5 class="mt-3">
                No hay menús registrados
            </h5>

        </div>
    }
    else
    {
        <div class="menu-table-wrap">

            <div class="table-responsive">

                <table class="table menu-table mb-0">

                    <thead>

                        <tr>
                            <th>Menú</th>
                            <th>Descripción</th>
                            <th>Disponibilidad</th>
                            <th>Horario</th>
                            <th class="text-center">Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            /*
                            * El estado se obtiene directamente
                            * del estado guardado en la base de datos.
                            *
                            * 1 = Activo
                            * 2 = Inactivo
                            */
                            bool estadoActivo =
                            item.IdEstadoMenu == 1;

                            <tr>

                                <td>

                                    <strong>
                                        @item.NombreMenu
                                    </strong>

                                </td>

                                <td class="descripcion-menu">
                                    @item.Descripcion
                                </td>

                                <td class="fecha-columna">

                                    @item.FechaInicio.ToString("dd/MM/yyyy")

                                    <span class="mx-1">
                                        -
                                    </span>

                                    @item.FechaFinal.ToString("dd/MM/yyyy")

                                </td>

                                <td class="horario-columna">

                                    @item.HoraInicio.ToString("HH:mm")

                                    <span class="mx-1">
                                        -
                                    </span>

                                    @item.HoraFinal.ToString("HH:mm")

                                </td>

                                <td class="text-center">

                                    @if (estadoActivo)
                                    {
                                        <span class="badge-activo">

                                            @if (!string.IsNullOrWhiteSpace(
                                                                            item.NombreEstado))
                                            {
                                                @item.NombreEstado
                                            }
                                            else
                                            {
                                                <text>Activo</text>
                                            }

                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge-inactivo">

                                            @if (!string.IsNullOrWhiteSpace(
                                                                            item.NombreEstado))
                                            {
                                                @item.NombreEstado
                                            }
                                            else
                                            {
                                                <text>Inactivo</text>
                                            }

                                        </span>
                                    }

                                </td>

                                <td class="text-center">

                                    <a asp-controller="Menu"
                                       asp-action="Edit"
                                       asp-route-id="@item.IdMenu"
                                       class="btn-accion-menu">

                                        <i class="bi bi-pencil-square"></i>
                                        Actualizar

                                    </a>

                                </td>

                            </tr>
                        }

                    </tbody>

                    <tfoot>

                        <tr>

                            <td colspan="6">

                                <div class="d-flex justify-content-end">

                                    @Html.PagedListPager(
                                    Model,
                                                                page => Url.Action(
                                                                "IndexAdmin",
                                                                "Menu",
                                                                new
                                                                {
                                                                    page
                                                                }),
                                                                new PagedListRenderOptions
                                                                {
                                                                    Display =
                                                                PagedListDisplayMode.Always,

                                                                    MaximumPageNumbersToDisplay =
                                                                5,

                                                                    LiElementClasses =
                                                                new[]
                                                                {
                                                                "page-item"
                                                                },

                                                                    PageClasses =
                                                                new[]
                                                                {
                                                                "page-link"
                                                                }
                                                                })

                            </div>

                        </td>

                    </tr>

                </tfoot>

            </table>

        </div>

    </div>
        }

</div>

@section Scripts
{
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @if (TempData["MensajeExito"] != null)
    {
        <script>
            Swal.fire({
                icon: "success",
                title: @Html.Raw(
                                System.Text.Json.JsonSerializer.Serialize(
                                        TempData["MensajeExito"]?.ToString()
                                )
                        ),
        confirmButtonText: "Aceptar"
    });
</script>
    }
}