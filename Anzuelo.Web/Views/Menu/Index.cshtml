@model IEnumerable<Anzuelo.Application.DTOs.MenuDTO>

@{
    ViewData["Title"] = "Menús";
}

<style>
    .menu-table-wrap {
        background: #fff;
        border-radius: .5rem;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(10, 47, 90, .08);
    }

    .menu-table thead th {
        background-color: var(--anzuelo-primary);
        color: #fff;
        font-size: .76rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        border: none;
        padding: .9rem 1.2rem;
    }

    .menu-table tbody tr {
        border-bottom: 1px solid #edf0f2;
        transition: background .15s;
    }

        .menu-table tbody tr:hover {
            background: #fff5ee;
        }

    .menu-table td {
        padding: .85rem 1.2rem;
        vertical-align: middle;
        border: none;
    }

    .badge-activo {
        background: var(--anzuelo-success);
        color: #fff;
        padding: .3rem .8rem;
        border-radius: 2rem;
        font-size: .75rem;
        font-weight: 700;
    }

    .badge-inactivo {
        background: #6c757d;
        color: #fff;
        padding: .3rem .8rem;
        border-radius: 2rem;
        font-size: .75rem;
        font-weight: 700;
    }

    .btn-menu-disponible {
        background: var(--anzuelo-accent);
        color: #fff;
        border: none;
        padding: .6rem 1.2rem;
        border-radius: .4rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        transition: opacity .2s;
    }

        .btn-menu-disponible:hover {
            opacity: .85;
            color: #fff;
        }

    .top-action {
        display: flex;
        justify-content: flex-end;
        margin-bottom: 1rem;
    }
</style>

<div class="page-hero">
    <div class="container">
        <h1><i class="bi bi-journal-text me-2"></i>Menús</h1>
        <p class="page-hero-sub">Gestión de menús del restaurante</p>
    </div>
</div>

<div class="container">

    <div class="top-action">
        <a asp-action="Details" class="btn-menu-disponible">
            Ver menú disponible
            <i class="bi bi-eye"></i>
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox" style="font-size:3rem;opacity:.4;"></i>
            <h5 class="mt-3">No hay menús registrados</h5>
        </div>
    }
    else
    {
        <div class="menu-table-wrap">
            <table class="table menu-table mb-0">
                <thead>
                    <tr>
                        <th>Menú</th>
                        <th>Descripción</th>
                        <th>Disponibilidad</th>
                        <th>Horario</th>
                        <th class="text-center">Estado</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        var ahora = DateTime.Now;

                        var inicio = item.FechaInicio.Date + item.HoraInicio.TimeOfDay;
                        var fin = item.FechaFinal.Date + item.HoraFinal.TimeOfDay;

                        bool activo = ahora >= inicio && ahora <= fin;

                        <tr>
                            <td><strong>@item.NombreMenu</strong></td>
                            <td>@item.Descripcion</td>

                            <td>
                                @item.FechaInicio.ToString("dd/MM/yyyy")
                                -
                                @item.FechaFinal.ToString("dd/MM/yyyy")
                            </td>

                            <td>
                                @item.HoraInicio.ToString(@"hh\:mm")
                                -
                                @item.HoraFinal.ToString(@"hh\:mm")
                            </td>

                            <td class="text-center">
                                @if (activo)
                                {
                                    <span class="badge-activo">Activo</span>
                                }
                                else
                                {
                                    <span class="badge-inactivo">Inactivo</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>