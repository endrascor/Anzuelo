@model IEnumerable<Anzuelo.Application.DTOs.UsuarioDTO>

@{
    ViewData["Title"] = "Listado de Usuarios (Dilan Sanchez Acuña)";
}

<style>
    .usuario-table-wrap {
        background: #fff;
        border-radius: .5rem;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(10, 47, 90, .08);
    }

    .usuario-table thead th {
        background-color: var(--anzuelo-primary);
        color: #fff;
        font-size: .76rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        border: none;
        padding: .9rem 1.2rem;
    }

    .usuario-table tbody tr {
        border-bottom: 1px solid #edf0f2;
        transition: background .15s;
    }

        .usuario-table tbody tr:hover {
            background: #fff5ee;
        }

    .usuario-table td {
        padding: .85rem 1.2rem;
        vertical-align: middle;
        border: none;
    }

    .btn-ver-usu {
        background: transparent;
        border: 2px solid var(--anzuelo-accent);
        color: var(--anzuelo-accent);
        font-size: .8rem;
        font-weight: 600;
        padding: .28rem .85rem;
        border-radius: .35rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        transition: background .2s, color .2s;
    }

    .badge-activo {
        background: var(--anzuelo-success);
        color: #fff;
        padding: .3rem .8rem;
        border-radius: 2rem;
        font-size: .75rem;
        font-weight: 700;
    }

    .badge-inactivo {
        background: #6c757d;
        color: #fff;
        padding: .3rem .8rem;
        border-radius: 2rem;
        font-size: .75rem;
        font-weight: 700;
    }

    .top-action {
        display: flex;
        justify-content: flex-end;
        margin-bottom: 1rem;
    }
</style>

<div class="page-hero">
    <div class="container">
        <h1><i class="bi bi-journal-text me-2"></i>Listado de Usuarios (Dilan Sanchez Acuña)</h1>
        <p class="page-hero-sub">Gestión de Usuario del Sistema</p>
    </div>
</div>

<div class="container">
    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox" style="font-size:3rem;opacity:.4;"></i>
            <h5 class="mt-3">No hay usuarios registrados</h5>
        </div>
    }
    else
    {
        <div class="usuario-table-wrap">
            <table class="table usuario-table mb-0">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Cedula</th>
                        <th>Nombre</th>
                        <th>Rol</th>
                        <th class="text-center">Estado</th>
                        <th class="text-center">Detalle</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.IdUsuario</td>
                            <td>@item.Cedula</td>
                            <td>@item.Nombre @item.Apellido1 @item.Apellido2</td>
                            <td>@item.NombreRol</td>
                            <td class="text-center">@item.NombreEstado</td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.IdUsuario"
                                   class="btn-ver-usu">
                                    Ver detalle
                                    <i class="bi bi-arrow-right"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>