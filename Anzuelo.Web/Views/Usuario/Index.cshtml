@model IEnumerable<Anzuelo.Application.DTOs.UsuarioDTO>
@{
    ViewData["Title"] = "Lista de Usuarios";
}

<style>
    .usr-table-wrap {
        background: #fff;
        border-radius: .5rem;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(10, 47, 90, .08);
    }

    .usr-table thead th {
        background-color: var(--anzuelo-primary);
        color: #fff;
        font-size: .76rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        border: none;
        padding: .9rem 1.2rem;
    }

    .usr-table tbody tr {
        border-bottom: 1px solid #edf0f2;
        transition: background .15s;
    }

        .usr-table tbody tr:last-child {
            border-bottom: none;
        }

        .usr-table tbody tr:hover {
            background: #fff5ee;
        }

    .usr-table td {
        padding: .85rem 1.2rem;
        vertical-align: middle;
        border: none;
    }

    .btn-ver-usr {
        background: transparent;
        border: 2px solid var(--anzuelo-accent);
        color: var(--anzuelo-accent);
        font-size: .8rem;
        font-weight: 600;
        padding: .28rem .85rem;
        border-radius: .35rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        transition: background .2s, color .2s;
    }

        .btn-ver-usr:hover {
            background: var(--anzuelo-accent);
            color: #fff;
        }

    .badge-rol {
        background: var(--anzuelo-primary);
        color: #fff;
        font-size: .75rem;
        font-weight: 600;
        padding: .25em .7em;
        border-radius: 2rem;
    }

    .badge-estado {
        font-size: .75rem;
        font-weight: 600;
        padding: .3em .75em;
        border-radius: 2rem;
        text-transform: uppercase;
        letter-spacing: .03em;
    }

    .badge-estado-activo {
        background: #e6f4ea;
        color: #1e7e34;
    }

    .badge-estado-inactivo {
        background: #f8d7da;
        color: #a71d2a;
    }
</style>

<div class="page-hero">
    <div class="container">
        <h1><i class="bi bi-people me-2"></i>Lista de Usuarios (Adrián Rojas Murillo)</h1>
        <p class="page-hero-sub">Usuarios registrados en el sistema</p>
    </div>
</div>

<div class="container">
    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox" style="font-size:3rem;opacity:.4;"></i>
            <h5 class="mt-3">No hay usuarios registrados aún</h5>
        </div>
    }
    else
    {
        <div class="usr-table-wrap">
            <table class="table usr-table mb-0">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Nombre</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th>Correo</th>
                        <th class="text-center">Detalle</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.IdUsuario</td>
                            <td><strong>@item.Nombre @item.Apellido1 @item.Apellido2</strong></td>
                            <td><span class="badge-rol">@item.NombreRol</span></td>
                            <td>
                                <span class="badge-estado @(item.NombreEstado.ToLower() == "activo" ? "badge-estado-activo" : "badge-estado-inactivo")">
                                    @item.NombreEstado
                                </span>
                            </td>
                            <td>@item.Email</td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.IdUsuario"
                                   class="btn-ver-usr">
                                    Ver detalle <i class="bi bi-arrow-right"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>