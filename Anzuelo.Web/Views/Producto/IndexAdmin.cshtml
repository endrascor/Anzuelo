@using X.PagedList
@using X.PagedList.Mvc.Core
@model X.PagedList.IPagedList<Anzuelo.Application.DTOs.ProductoDTO>
@{
    ViewData["Title"] = "Administrar Productos";
}

<style>
    .prod-table-wrap {
        background: #fff;
        border-radius: .5rem;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(10, 47, 90, .08);
    }

    .prod-table thead th {
        background-color: var(--anzuelo-primary);
        color: #fff;
        font-size: .76rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        border: none;
        padding: .9rem 1.2rem;
    }

    .prod-table tbody tr {
        border-bottom: 1px solid #edf0f2;
        transition: background .15s;
    }

        .prod-table tbody tr:last-child {
            border-bottom: none;
        }

        .prod-table tbody tr:hover {
            background: #fff5ee;
        }

    .prod-table td {
        padding: .85rem 1.2rem;
        vertical-align: middle;
        border: none;
    }

    .btn-ver-prod {
        background: transparent;
        border: 2px solid var(--anzuelo-accent);
        color: var(--anzuelo-accent);
        font-size: .8rem;
        font-weight: 600;
        padding: .28rem .85rem;
        border-radius: .35rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        transition: background .2s, color .2s;
    }

        .btn-ver-prod:hover {
            background: var(--anzuelo-accent);
            color: #fff;
        }

    .badge-categoria {
        background: var(--anzuelo-primary);
        color: #fff;
        font-size: .75rem;
        font-weight: 600;
        padding: .25em .7em;
        border-radius: 2rem;
    }

    .precio-col {
        font-weight: 700;
        color: var(--anzuelo-accent);
    }

    .pagination .page-link {
        color: var(--anzuelo-primary);
        border-color: #dee2e6;
        font-size: .85rem;
        padding: .35rem .75rem;
    }

    .pagination .page-item.active .page-link {
        background-color: var(--anzuelo-primary);
        border-color: var(--anzuelo-primary);
        color: #fff;
    }

    .pagination .page-link:hover {
        background-color: #fff5ee;
        color: var(--anzuelo-accent);
        border-color: var(--anzuelo-accent);
    }
</style>

<div class="page-hero">
    <div class="container">
        <h1><i class="bi bi-box-seam me-2"></i>Administrar Productos</h1>
        <p class="page-hero-sub">Gestión de productos registrados en el sistema</p>
    </div>
</div>

<div class="container">
    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox" style="font-size:3rem;opacity:.4;"></i>
            <h5 class="mt-3">No hay productos registrados aún</h5>
        </div>
    }
    else
    {
        <div class="prod-table-wrap">
            <table class="table prod-table mb-0">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Categoría</th>
                        <th>Precio</th>
                        <th class="text-center">Detalle</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.Nombre</strong></td>
                            <td>@item.Descripcion</td>
                            <td><span class="badge-categoria">@item.NombreCategoria</span></td>
                            <td class="precio-col">₡@item.Precio.ToString("N2")</td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.IdProducto"
                                   class="btn-ver-prod">
                                    Ver detalle <i class="bi bi-arrow-right"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="5">
                            <div class="d-flex justify-content-end">
                                @Html.PagedListPager((IPagedList)Model, page =>
                                Url.Action("IndexAdmin", new { page }), new PagedListRenderOptions
                                {
                                    Display = PagedListDisplayMode.Always,
                                    MaximumPageNumbersToDisplay = 5,
                                    LiElementClasses = new String[] { "page-item" },
                                    PageClasses = new String[] { "page-link" }
                                })
                        </div>
                    </td>
                </tr>
            </tfoot>
        </table>
    </div>
        }
</div>