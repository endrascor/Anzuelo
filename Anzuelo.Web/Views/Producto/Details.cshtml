@model Anzuelo.Application.DTOs.ProductoDTO

@{
    ViewData["Title"] = "Detalle del Producto";
}

<style>
    .page-hero {
        background: linear-gradient(135deg, var(--anzuelo-primary), #184f8a);
        color: #fff;
        padding: 1.8rem 0;
        margin-bottom: 1.5rem;
        border-radius: .5rem;
    }

        .page-hero h1 {
            font-weight: 700;
            margin: 0;
        }

    .page-hero-sub {
        opacity: .9;
        font-size: .95rem;
    }

    .detail-card {
        border: none;
        border-left: 4px solid var(--anzuelo-accent);
        border-radius: .5rem;
        background: #fff;
    }

    .carousel-item img,
    .img-fluid {
        border-radius: .5rem;
        box-shadow: 0 3px 12px rgba(10, 47, 90, .10);
        background: #fff;
    }

    h3 {
        color: var(--anzuelo-primary);
        font-weight: 700;
    }

    .price {
        font-size: 1.6rem;
        font-weight: 800;
        color: var(--anzuelo-accent);
    }

    .ingredients-card {
        border: none;
        border-left: 4px solid var(--anzuelo-accent);
        border-radius: .5rem;
        background: #fff;
    }

    .list-group-item {
        border: none;
        border-bottom: 1px solid #eee;
    }

    .btn-back {
        background: transparent;
        border: 2px solid var(--anzuelo-accent);
        color: var(--anzuelo-accent);
        font-weight: 600;
        border-radius: .4rem;
        padding: .45rem 1rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        transition: .2s;
    }

        .btn-back:hover {
            background: var(--anzuelo-accent);
            color: #fff;
        }
</style>

<div class="page-hero text-center">
    <div class="container">
        <h1><i class="bi bi-box-seam me-2"></i>Detalle del Producto</h1>
        <p class="page-hero-sub">@Model.Nombre</p>
    </div>
</div>

<div class="container">

    <div class="card detail-card shadow-sm p-4">

        <div class="row">

            <div class="col-md-5 text-center">

                @if (Model.Imagenes.Any())
                {
                    <div id="productoCarousel" class="carousel slide" style="height:350px;">

                        <div class="carousel-inner">

                            @{
                                bool primera = true;
                            }

                            @foreach (var imagen in Model.Imagenes)
                            {
                                <div class="carousel-item @(primera ? "active" : "")">

                                    <div class="d-flex justify-content-center align-items-center" style="height:350px;">

                                        <img src="data:image/jpeg;base64,@Convert.ToBase64String(imagen.Imagen)"
                                             class="img-fluid"
                                             alt="@Model.Nombre"
                                             style="max-height:330px; max-width:100%; object-fit:contain;" />

                                    </div>

                                </div>

                                primera = false;
                            }

                        </div>

                        @if (Model.Imagenes.Count > 1)
                        {
                            <button class="carousel-control-prev" type="button" data-bs-target="#productoCarousel" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon bg-dark rounded-circle"></span>
                            </button>

                            <button class="carousel-control-next" type="button" data-bs-target="#productoCarousel" data-bs-slide="next">
                                <span class="carousel-control-next-icon bg-dark rounded-circle"></span>
                            </button>
                        }

                    </div>
                }
                else if (Model.Imagen != null)
                {
                    <div class="d-flex justify-content-center align-items-center" style="height:350px;">

                        <img src="data:image/jpeg;base64,@Convert.ToBase64String(Model.Imagen)"
                             class="img-fluid"
                             alt="@Model.Nombre"
                             style="max-height:330px; max-width:100%; object-fit:contain;" />

                    </div>
                }

            </div>

            <div class="col-md-7 d-flex flex-column justify-content-center">

                <h3>@Model.Nombre</h3>

                <hr />

                <p><strong>Descripción:</strong><br />@Model.Descripcion</p>

                <p><strong>Categoría:</strong> @Model.NombreCategoria</p>

                <h3 class="price">₡@Model.Precio.ToString("N2")</h3>

            </div>

        </div>

    </div>

    <div class="card ingredients-card shadow-sm mt-4">

        <div class="card-body">

            <h4 style="color:var(--anzuelo-primary);font-weight:700;">Ingredientes</h4>

            @if (Model.Ingredientes.Any())
            {
                <ul class="list-group">
                    @foreach (var ingrediente in Model.Ingredientes)
                    {
                        <li class="list-group-item">
                            @ingrediente.NombreIngrediente
                        </li>
                    }
                </ul>
            }
            else
            {
                <div class="alert alert-info">
                    Este producto no tiene ingredientes registrados.
                </div>
            }

        </div>

    </div>

    <div class="mt-4">
        <a href="javascript:history.back()" class="btn-back">
            <i class="bi bi-arrow-left"></i> Volver a Productos
        </a>
    </div>

</div>

@section Scripts
{
    @if (Model.Imagenes.Count > 1)
    {
        <script>
            const carouselElement = document.getElementById('productoCarousel');

            new bootstrap.Carousel(carouselElement, {
                interval: 3000,
                ride: 'carousel'
            });
        </script>
    }
}