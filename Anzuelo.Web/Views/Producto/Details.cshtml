@model Anzuelo.Application.DTOs.ProductoDTO

@{
    ViewData["Title"] = "Detalle del Producto";
}

<h1 class="mb-4">@Model.Nombre</h1>

<div class="card shadow-sm p-4">

    <div class="row">

        <!-- Imagen -->
        <div class="col-md-5 text-center">

            @if (Model.Imagenes.Any())
            {
                <div id="productoCarousel"
                     class="carousel slide"
                     style="height:350px;">

                    <div class="carousel-inner">

                        @{
                            bool primera = true;
                        }

                        @foreach (var imagen in Model.Imagenes)
                        {
                            <div class="carousel-item @(primera ? "active" : "")">

                                <div class="d-flex justify-content-center align-items-center"
                                     style="height:350px;">

                                    <img src="data:image/jpeg;base64,@Convert.ToBase64String(imagen.Imagen)"
                                         class="img-fluid rounded"
                                         alt="@Model.Nombre"
                                         style="max-height:330px;
                                                        max-width:100%;
                                                        object-fit:contain;" />

                                </div>

                            </div>

                            primera = false;
                        }

                    </div>

                    @if (Model.Imagenes.Count > 1)
                    {
                        <button class="carousel-control-prev"
                                type="button"
                                data-bs-target="#productoCarousel"
                                data-bs-slide="prev">

                            <span class="carousel-control-prev-icon bg-dark rounded-circle"></span>

                        </button>

                        <button class="carousel-control-next"
                                type="button"
                                data-bs-target="#productoCarousel"
                                data-bs-slide="next">

                            <span class="carousel-control-next-icon bg-dark rounded-circle"></span>

                        </button>
                    }

                </div>
            }
            else if (Model.Imagen != null)
            {
                <div class="d-flex justify-content-center align-items-center"
                     style="height:350px;">

                    <img src="data:image/jpeg;base64,@Convert.ToBase64String(Model.Imagen)"
                         class="img-fluid rounded"
                         alt="@Model.Nombre"
                         style="max-height:330px;
                                    max-width:100%;
                                    object-fit:contain;" />

                </div>
            }

        </div>

        <!-- Información -->
        <div class="col-md-7 d-flex flex-column justify-content-center">

            <h3>@Model.Nombre</h3>

            <hr />

            <p>
                <strong>Descripción:</strong><br />
                @Model.Descripcion
            </p>

            <p>
                <strong>Categoría:</strong>
                @Model.NombreCategoria
            </p>

            <h3 class="text-primary">
                ₡@Model.Precio.ToString("N2")
            </h3>

        </div>

    </div>

</div>

<div class="card shadow-sm mt-4">

    <div class="card-body">

        <h4>Ingredientes</h4>

        @if (Model.Ingredientes.Any())
        {
            <ul class="list-group">

                @foreach (var ingrediente in Model.Ingredientes)
                {
                    <li class="list-group-item">
                        @ingrediente.NombreIngrediente
                    </li>
                }

            </ul>
        }
        else
        {
            <div class="alert alert-info">
                Este producto no tiene ingredientes registrados.
            </div>
        }

    </div>

</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">
        Volver
    </a>
</div>

@section Scripts
{
    @if (Model.Imagenes.Count > 1)
    {
        <script>
            const carouselElement = document.getElementById('productoCarousel');

            new bootstrap.Carousel(carouselElement, {
                interval: 3000,
                ride: 'carousel'
            });
        </script>
    }
}